# Copy to .env and replace with your local credentials
NUMIX_DB_URL=jdbc:postgresql://localhost:54326/numixdb
NUMIX_DB_USERNAME=admin
NUMIX_DB_PASSWORD=replace_me

# docker-compose runtime secrets/config
POSTGRES_DB=numixdb
POSTGRES_USER=admin
POSTGRES_PASSWORD=replace_me
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace_me
REDIS_PASSWORD=replace_me

# Optional existing app vars used by docker-compose
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=